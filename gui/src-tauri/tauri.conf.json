{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureModelRoute",
  "version": "0.1.0",
  "identifier": "com.securemodelroute.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SecureModelRoute",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "url": "http://127.0.0.1:8080/ui"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"]
  }
}
