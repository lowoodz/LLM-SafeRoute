{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SafeRoute",
  "version": "0.1.1",
  "identifier": "com.securemodelroute.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LLM-SafeRoute",
        "hiddenTitle": true,
        "titleBarStyle": "Transparent",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "url": "bootstrap.html",
        "dragDropEnabled": true,
        "theme": "Dark",
        "backgroundColor": "#2e323a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
