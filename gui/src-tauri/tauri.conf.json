{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureModelRoute",
  "version": "0.1.0",
  "identifier": "com.securemodelroute.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SecureModelRoute",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "url": "http://127.0.0.1:8080/ui",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
