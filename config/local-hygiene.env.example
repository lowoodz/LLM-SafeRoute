# Copy to config/local-hygiene.env (gitignored).
# Used only by scripts/check-commit-hygiene.sh — never commit this file.
#
# Comma-separated strings that must not appear in staged source (your macOS username,
# Windows VM SSH user, email local-part, etc.).
SMR_HYGIENE_BLOCK_IDENTIFIERS=your-mac-username,your-windows-username
