# Copy to config/test.env (gitignored) and fill in values for live/blackbox tests.
# Scripts load this file automatically via scripts/load_test_env.sh (bash) or load_test_env.ps1 (PowerShell).
#
# Legacy alternative: copy test_model_api_key.example.txt → test_model_api_key.txt and set SMR_KEYS_FILE.

# --- Required for live / blackbox / stress tests ---
SMR_GLM_API_KEY=
SMR_DEEPSEEK_API_KEY=

# --- Provider endpoints (defaults match production APIs) ---
SMR_GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
SMR_GLM_ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
SMR_DEEPSEEK_BASE_URL=https://api.deepseek.com
SMR_DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# --- Optional overrides ---
# SMR_KEYS_FILE=              # legacy keys file (used when SMR_*_API_KEY unset)
# SMR_TEST_ENV=               # override path to this env file
# SMR_BIN=                    # path to smr binary

# --- Windows SSH remote test (scripts/windows_vm_test.sh) ---
# SMR_WINDOWS_HOST=           # SSH HostName or ~/.ssh/config Host alias
# SMR_WINDOWS_USER=           # SSH user on the Windows VM
SMR_WINDOWS_REMOTE_DIR=/c/Users/Public/smr-test

# --- UTM / VM (optional) ---
# SMR_VM_DIR=
# SMR_VM_NAME=
# SMR_SKIP_VM_TESTS=1
