# LOCAL ONLY — copy to config/test.env (gitignored). Never commit config/test.env.
#
# Single place for machine-specific test/runtime settings:
#   - API keys (SMR_GLM_API_KEY, SMR_DEEPSEEK_API_KEY)
#   - Windows UTM SSH user / guest staging paths
# Scripts load this via scripts/load_test_env.sh (bash) or load_test_env.ps1 (PowerShell).
#
# Legacy alternative: copy test_model_api_key.example.txt → test_model_api_key.txt (also gitignored).
# Pre-commit: ./scripts/install-git-hooks.sh then commits are scanned by check-commit-hygiene.sh

# --- Required for live / blackbox / stress tests ---
SMR_GLM_API_KEY=
SMR_DEEPSEEK_API_KEY=

# --- Provider endpoints (defaults match production APIs) ---
SMR_GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
SMR_GLM_ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
SMR_DEEPSEEK_BASE_URL=https://api.deepseek.com
SMR_DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# --- Optional overrides ---
# SMR_KEYS_FILE=              # legacy keys file (used when SMR_*_API_KEY unset)
# SMR_TEST_ENV=               # override path to this env file
# SMR_BIN=                    # path to smr binary

# --- Dev binary: bundled pdftotext for PDF file DLP indexing ---
# SMR_TOOLS_DIR=              # set automatically by scripts/run-dev.sh; required for dev PDF index if not using release install

# --- Windows UTM guest (SSH compile / pack / test — see scripts/vm/WINDOWS_VM.md) ---
# Host alias from ~/.ssh/config (not a fixed IP — set per machine).
SMR_WINDOWS_HOST=windows-vm
# SSH login on the Windows VM (must match the account you created in the guest).
SMR_WINDOWS_USER=windows-user
# Guest staging root (build logs, test zips, python embed). Default: C:/Users/<SMR_WINDOWS_USER>/smr-staging
SMR_GUEST_STAGING=C:/Users/windows-user/smr-staging
# Legacy zip-install test remote dir (scripts/windows_vm_test.sh)
SMR_WINDOWS_REMOTE_DIR=/c/Users/windows-user/smr-staging/smr-test

# --- OpenClaw security matrix (portable fixtures; macOS / Windows VM) ---
# SMR_MATRIX_ROOT=              # default: $TMPDIR/smr-matrix or $SMR_GUEST_STAGING/smr-matrix on VM
# SMR_CONFIG_DIR=               # override SafeRoute config dir (default: platform standard)
# Run: ./scripts/run_openclaw_matrix.sh   (macOS/Linux host)
#      ./scripts/vm/run-openclaw-matrix.sh (Windows UTM guest via SSH)

# --- UTM / VM (optional) ---
# SMR_VM_DIR=
# SMR_VM_NAME=
# SMR_SKIP_VM_TESTS=1
